public class TransactionLookup {
    // Linear Search for first and last occurrence [cite: 120]
    public static void findOccurrencesLinear(String[] logs, String targetId) {
        int first = -1, last = -1;
        for (int i = 0; i < logs.length; i++) {
            if (logs[i].equals(targetId)) {
                if (first == -1) first = i;
                last = i;
            }
        }
        System.out.println("First: " + first + ", Last: " + last);
    }

    // Binary Search to count occurrences in a sorted array [cite: 121, 122]
    public static int countOccurrencesBinary(String[] sortedLogs, String targetId) {
        int first = findBound(sortedLogs, targetId, true);
        if (first == -1) return 0;
        int last = findBound(sortedLogs, targetId, false);
        return last - first + 1;
    }

    private static int findBound(String[] arr, String target, boolean isFirst) {
        int low = 0, high = arr.length - 1, res = -1;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            int comp = target.compareTo(arr[mid]);
            if (comp == 0) {
                res = mid;
                if (isFirst) high = mid - 1; // Keep searching left
                else low = mid + 1;        // Keep searching right
            } else if (comp < 0) high = mid - 1;
            else low = mid + 1;
        }
        return res;
    }
}
